// Set the variable to 1000
const int LED_PIN = 5;

void setup() {
  // initialize digital pin LED_Builtin as an output.
  pinMode(LED_PIN, OUTPUT);
}

// Main loop.
void loop() {
  // Turn the pin on (HIGH is the voltage level) for 1000 ms.
  digitalWrite(LED_PIN, HIGH);
  delay(1000);

  // Turn the pin on (HIGH is the voltage level) for 1000 ms.
  digitalWrite(LED_PIN, LOW);
  delay(1000);
}
